#!/usr/bin/env bash
set -euo pipefail

die() { echo "ERROR: $*" >&2; exit 1; }

usage() {
  cat <<'EOF'
Usage: parse-xlsx <file.xlsx> [sheet_index|sheet_name] [--max-rows N] [--max-cols N]

Parse XLSX to TSV. Python stdlib only — no pip packages.
If sheet is omitted, lists sheet names and exits.

Options:
  --max-rows N   Limit output rows (default: all)
  --max-cols N   Limit output columns (default: all)

Examples:
  parse-xlsx report.xlsx                # list sheets
  parse-xlsx report.xlsx 0              # first sheet, all rows
  parse-xlsx report.xlsx 1 --max-rows 20
  parse-xlsx report.xlsx "Crops"        # sheet by name
EOF
  exit 1
}

main() {
  local xlsx="${1:-}" sheet="" max_rows=0 max_cols=0
  [[ -n "$xlsx" ]] || usage
  shift
  # Second positional arg is sheet (optional, may start with - for flags)
  if [[ $# -gt 0 && ! "$1" =~ ^-- ]]; then
    sheet="$1"; shift
  fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max-rows) max_rows="$2"; shift 2 ;;
      --max-cols)  max_cols="$2"; shift 2 ;;
      -h|--help) usage ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  # Escape paths for Safe Python embedding
  local xlsx_escaped sheet_escaped
  xlsx_escaped=$(printf '%s' "$xlsx" | sed "s/'/'\\\\''/g")
  sheet_escaped=$(printf '%s' "$sheet" | sed "s/'/'\\\\''/g")

  exec python3 - "$xlsx_escaped" "$sheet_escaped" "$max_rows" "$max_cols" <<'PYEOF'
import zipfile, xml.etree.ElementTree as ET, sys, os

xlsx_path = sys.argv[1]
sheet_arg = sys.argv[2] if len(sys.argv) > 2 else ''
max_rows = int(sys.argv[3]) if len(sys.argv) > 3 else 0
max_cols = int(sys.argv[4]) if len(sys.argv) > 4 else 0

NS = 'http://schemas.openxmlformats.org/spreadsheetml/2006/main'

def col_letter_to_num(s):
    n = 0
    for ch in s.upper():
        n = n * 26 + (ord(ch) - ord('A') + 1)
    return n

with zipfile.ZipFile(xlsx_path, 'r') as z:
    # Shared strings
    sst = []
    if 'xl/sharedStrings.xml' in z.namelist():
        root = ET.parse(z.open('xl/sharedStrings.xml')).getroot()
        sst = []
    for si in root.findall(f'{{{NS}}}si'):
        t_el = si.find(f'{{{NS}}}t')
        sst.append(t_el.text if t_el is not None and t_el.text else '')

    # Sheet list
    wb = ET.parse(z.open('xl/workbook.xml')).getroot()
    sheets_el = wb.find(f'{{{NS}}}sheets')
    sheet_names = [s.get('name') for s in sheets_el.findall(f'{{{NS}}}sheet')] if sheets_el is not None else []

    if not sheet_arg:
        for i, name in enumerate(sheet_names):
            print(f'{i}\t{name}')
        sys.exit(0)

    # Resolve sheet index by number or name
    s_idx = -1
    if sheet_arg.isdigit():
        s_idx = int(sheet_arg)
    else:
        for i, name in enumerate(sheet_names):
            if name.lower() == sheet_arg.lower():
                s_idx = i
                break
    if s_idx < 0 or s_idx >= len(sheet_names):
        print(f'Sheet not found: {sheet_arg}. Available:', file=sys.stderr)
        for i, name in enumerate(sheet_names):
            print(f'  {i}\t{name}', file=sys.stderr)
        sys.exit(1)

    # Read sheet XML — try numbered file, then any match
    sheet_idx = s_idx + 1
    candidates = [f for f in z.namelist() if f.startswith('xl/worksheets/sheet')]
    sheet_file = f'xl/worksheets/sheet{sheet_idx}.xml'
    if sheet_file not in z.namelist() and s_idx < len(candidates):
        sheet_file = sorted(candidates)[s_idx]

    root = ET.parse(z.open(sheet_file)).getroot()
    rows = root.findall(f'{{{NS}}}sheetData/{{{NS}}}row')

    if not rows:
        sys.exit(0)

    # Determine column range
    all_refs = []
    for row in rows:
        for c in row.findall(f'{{{NS}}}c'):
            ref = c.get('r', '')
            if ref:
                all_refs.append(ref)
    max_c = max((col_letter_to_num(''.join(ch for ch in r if ch.isalpha())) for r in all_refs), default=0)
    if max_cols > 0:
        max_c = min(max_c, max_cols)

    # Build cell data dict
    cells = {}
    max_r = 0
    for row in rows:
        r = int(row.get('r', 0))
        max_r = max(max_r, r)
        for c in row.findall(f'{{{NS}}}c'):
            ref = c.get('r', '')
            c_num = col_letter_to_num(''.join(ch for ch in ref if ch.isalpha()))
            v_el = c.find(f'{{{NS}}}v')
            if v_el is None or v_el.text is None:
                continue
            val = v_el.text
            t = c.get('t', '')
            if t == 's':
                idx = int(val)
                val = sst[idx] if idx < len(sst) else ''
            elif t == 'b':
                val = 'TRUE' if val == '1' else 'FALSE'
            elif t == 'str':
                is_el = c.find(f'{{{NS}}}is/{{{NS}}}t')
                if is_el is not None and is_el.text:
                    val = is_el.text
            else:
                # Number cell: clean floating-point noise
                try:
                    v = float(val)
                    if v == int(v):
                        val = str(int(v))
                    else:
                        val = f'{v:.6f}'.rstrip('0').rstrip('.')
                except ValueError:
                    pass
            cells[(r, c_num)] = val

    # Output
    for row_num in range(1, max_r + 1):
        vals = [str(cells.get((row_num, c), '')) for c in range(1, max_c + 1)]
        line = '\t'.join(vals).rstrip('\t')
        if line.strip('\t'):
            print(line)
        if max_rows > 0 and row_num >= max_rows:
            break
PYEOF
}

main "$@"
