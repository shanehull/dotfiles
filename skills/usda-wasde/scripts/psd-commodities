#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<EOF
Usage: psd-commodities

List all PSD commodities with codes and descriptions.

Examples:
  psd-commodities
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    *) echo "Unknown: $1"; usage ;;
  esac
done

exec "$SCRIPT_DIR/psd-request" commodities
