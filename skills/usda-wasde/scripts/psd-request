#!/usr/bin/env bash
set -euo pipefail

die() { echo "ERROR: $*" >&2; exit 1; }

usage() {
  cat <<'EOF'
Usage: psd-request <path>

Generic PSD API request. Prepends the base URL and auth header.

PATH is the endpoint path after /api/psd/ (e.g. "commodities").

Requires USDA_FAS_API_KEY environment variable.

EXAMPLES:
  psd-request commodities
  psd-request countries
  psd-request commodityAttributes
  psd-request commodity/0440000/world/year/2026
  psd-request commodity/0440000/country/all/year/2026
  psd-request commodity/0440000/country/BR/year/2026
EOF
  exit 1
}

main() {
  [[ $# -ge 1 ]] || usage
  [[ "$1" == "-h" || "$1" == "--help" ]] && usage

  local path_spec="$1"
  local api_key="${USDA_FAS_API_KEY:-}"

  [[ -n "$api_key" ]] || die "USDA_FAS_API_KEY not set. Get a free key at https://api.data.gov/signup/"

  curl -sS -H "X-Api-Key: ${api_key}" "https://api.fas.usda.gov/api/psd/${path_spec}"
}

main "$@"
