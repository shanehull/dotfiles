{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "vimMode": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "120d",
      "warningAcknowledged": true
    }
  },
  "mcpServers": {
    "qmd": {
      "command": "qmd",
      "args": ["mcp"]
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp"
    },
    "gitlab": {
      "url": "https://gitlab.com/api/v4/mcp"
    },
    "obsidian-remote": {
      "httpUrl": "https://obsidian.shanehull.com/mcp",
      "oauth": {
        "clientId": "732346191627-u651rf1emjc2tmb3mpe5751g8qla4cgm.apps.googleusercontent.com",
        "scopes": ["openid", "email", "profile"]
      }
    }
  },
  "context": {
    "fileName": ["AGENTS.md"],
    "includeDirectories": ["$HOME/.config/", "$SECOND_BRAIN/0-inbox"],
    "loadMemoryFromIncludeDirectories": true
  }
}
