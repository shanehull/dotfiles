{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "vimMode": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "120d",
      "warningAcknowledged": true
    }
  },
  "mcpServers": {
    "qmd": {
      "command": "qmd",
      "args": ["mcp"]
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp"
    },
    "gitlab": {
      "url": "https://gitlab.com/api/v4/mcp"
    }
  },
  "context": {
    "fileName": ["AGENTS.md"],
    "includeDirectories": ["$HOME/.config/", "$SECOND_BRAIN/0-inbox"],
    "loadMemoryFromIncludeDirectories": true
  }
}
