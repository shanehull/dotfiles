{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "fred": {
      "type": "remote",
      "url": "https://fred.shanehull.com/mcp",
      "enabled": true
    },
    "ibkr": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "interactive-brokers-mcp"
      ],
      "enabled": true
    },
    "obsidian-remote": {
      "type": "remote",
      "url": "https://obsidian.shanehull.com/mcp",
      "enabled": true
    },
    "qmd": {
      "type": "local",
      "command": [
        "qmd",
        "mcp"
      ],
      "enabled": true
    },
    "remote": {
      "type": "remote",
      "url": "https://mcp.remote.com/mcp",
      "enabled": true
    },
    "yfinance": {
      "type": "local",
      "command": [
        "uvx",
        "yfmcp@latest"
      ],
      "enabled": true
    }
  },
  "lsp": true,
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "*/.config/opencode/skills/*/scripts/*": "allow",
      "basename *": "allow",
      "bun --version": "allow",
      "cat *": "allow",
      "curl": "ask",
      "curl --get*": "allow",
      "curl -X GET*": "allow",
      "curl -sS*": "allow",
      "date": "allow",
      "date *": "allow",
      "df *": "allow",
      "diff *": "allow",
      "dirname *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "env": "allow",
      "eslint": "allow",
      "eslint *": "allow",
      "file *": "allow",
      "find *": "allow",
      "git blame *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git config --get *": "allow",
      "git describe": "allow",
      "git describe *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git remote": "allow",
      "git remote *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git stash list": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git tag": "allow",
      "git tag -l*": "allow",
      "go build *": "allow",
      "go doc *": "allow",
      "go env": "allow",
      "go env *": "allow",
      "go fmt *": "allow",
      "go list *": "allow",
      "go mod download": "allow",
      "go mod download *": "allow",
      "go mod tidy": "allow",
      "go test *": "allow",
      "go version": "allow",
      "go vet *": "allow",
      "golangci-lint run *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "hostname": "allow",
      "jq *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "node --version": "allow",
      "npm --version": "allow",
      "npm ls": "allow",
      "npm ls *": "allow",
      "npm view *": "allow",
      "prettier --check*": "allow",
      "printf *": "allow",
      "pwd": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "tail *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "tsc --noEmit*": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "whoami": "allow",
      "yq *": "allow"
    },
    "task": "allow",
    "external_directory": "ask",
    "question": "allow",
    "webfetch": "allow",
    "doom_loop": "ask",
    "skill": "allow"
  }
}
