{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus[1m]",
  "enabledPlugins": {
    "mcps@shane-mcps": true,
    "linear@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "shane-mcps": {
      "source": {
        "source": "directory",
        "path": "~/.config/claude/marketplace"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(glab mr view *)",
      "Bash(glab mr diff *)",
      "Bash(glab ci trace *)",
      "Bash(glab auth status)",
      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl config current-context)",
      "Bash(helm template *)",
      "Bash(helm lint *)",
      "Bash(nix eval *)",
      "Bash(terragrunt plan *)",
      "Bash(aws sts get-caller-identity)",
      "Bash(aws ecr describe-images *)",
      "Bash(aws cloudwatch get-metric-statistics *)",
      "Bash(aws cloudtrail lookup-events *)",
      "mcp__plugin_gitlab_gitlab__search",
      "mcp__plugin_gitlab_gitlab__semantic_code_search",
      "mcp__plugin_gitlab_gitlab__get_merge_request",
      "mcp__plugin_gitlab_gitlab__get_merge_request_diffs",
      "mcp__plugin_slack_slack__slack_read_thread",
      "mcp__plugin_slack_slack__slack_search_public_and_private",
      "mcp__plugin_slack_slack__slack_search_channels",
      "mcp__plugin_linear_linear__list_issues",
      "mcp__plugin_Notion_notion__notion-fetch",
      "mcp__plugin_mcps_honeycomb__find_columns"
    ]
  },
  "theme": "dark-ansi"
}
