{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest"],
  "mcp": {
    "qmd": {
      "type": "local",
      "command": ["qmd", "mcp"],
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "gitlab": {
      "type": "remote",
      "url": "https://gitlab.com/api/v4/mcp",
      "enabled": true
    },
    "obsidian-remote": {
      "type": "remote",
      "url": "https://obsidian.shanehull.com/mcp",
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "question": "allow",
    "external_directory": "ask",
    "doom_loop": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "which *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "go test *": "allow",
      "golangci-lint run *": "allow"
    }
  }
}
